<?xml version="1.0" encoding="utf-8"?>
<!--
  sample-app/AndroidManifest.xml

  PYRX Synapse Android SDK — sample (Phase 8.4b Task 8.4b.13). Mirrors
  the iOS SwiftUIDemo's Info.plist surface:

    - POST_NOTIFICATIONS  : runtime permission for the push demo on API 33+.
                            On API ≤ 32 push works without the prompt.
    - INTERNET            : needed for the SDK's event POSTs.
    - ACCESS_NETWORK_STATE: read by the SDK's Reachability layer to time
                            queue drains around online/offline transitions.

  The synapse-push module ships its own AndroidManifest.xml declaring
  PyrxMessagingService — manifest merger picks it up automatically; we
  do NOT redeclare it here. If a host app wanted a custom service it would
  override with `tools:replace="android:name"`; the sample uses the
  default service so QA can verify the out-of-the-box flow.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SampleApplication"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PyrxSample">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PyrxSample">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Firebase BoM auto-provides the messaging service via synapse-push.
          The placeholder below would be the host-app override path; we leave
          it commented out so the default (com.google.firebase.messaging.
          FirebaseMessagingService → tech.pyrx.synapse.push.PyrxMessagingService
          via synapse-push manifest merge) wins.

          <service android:name="tech.pyrx.synapse.push.PyrxMessagingService"
                   android:exported="false">
              <intent-filter>
                  <action android:name="com.google.firebase.MESSAGING_EVENT" />
              </intent-filter>
          </service>
        -->
    </application>

</manifest>
