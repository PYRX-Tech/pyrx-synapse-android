root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
# ktlint rules
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_filename = enabled
ktlint_standard_function-naming = enabled
ktlint_standard_property-naming = enabled
# Allow trailing comma — matches Kotlin official style
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Compose @Composable functions are PascalCase by convention. ktlint's
# function-naming rule fights this — disable for the sample app where every
# screen + reusable bit is a Composable. Production SDK code (synapse-core,
# synapse-push, synapse-inapp) is unaffected and retains the standard rule.
[sample-app/**/*.kt]
ktlint_standard_function-naming = disabled

[*.{xml,yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
